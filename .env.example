# LLM Configuration
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=google/gemini-flash-1.5

# Embeddings Configuration
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_FALLBACK=true

# Database Configuration
DATABASE_URL=postgresql://cortex:cortex_pass@postgres:5432/incident_cortex

# ChromaDB Configuration
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=ecommerce_codebase

# E-commerce Repository Configuration
ECOMMERCE_REPO_URL=https://github.com/reactioncommerce/reaction.git
ECOMMERCE_REPO_BRANCH=trunk

# Deduplication Thresholds
DEDUP_SUGGESTION_THRESHOLD=0.85
DEDUP_DUPLICATE_THRESHOLD=0.95

# Mock Services Configuration
JIRA_MOCK_URL=http://jira-mock:8080
SLACK_MOCK_URL=http://slack-mock:8090
MAILHOG_SMTP_HOST=mailhog
MAILHOG_SMTP_PORT=1025
NOTIFICATION_FROM_EMAIL=cortex@incident-cortex.local
TEAM_EMAIL=sre-team@company.com
SLACK_CHANNEL=#incidents

# Langfuse Observability Configuration
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://langfuse:3000

# Application Configuration
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=10
RATE_LIMIT_PER_MINUTE=10
